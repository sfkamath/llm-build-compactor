#!/bin/sh
# Gradle wrapper for Java 11 (uses Gradle 8.5)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

GRADLE_WRAPPER_JAR="$SCRIPT_DIR/gradle/wrapper-gradle8.5/gradle-wrapper.jar"
GRADLE_WRAPPER_PROPS="$SCRIPT_DIR/gradle/wrapper-gradle8.5/gradle-wrapper.properties"

exec "$JAVACMD" -classpath "$GRADLE_WRAPPER_JAR" \
    -Dorg.gradle.wrapper.properties="$GRADLE_WRAPPER_PROPS" \
    org.gradle.wrapper.GradleWrapperMain "$@"
