#!/bin/sh
# Gradle wrapper for Java 11 (uses Gradle 8.5)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Use JAVA_HOME if set, otherwise try to find Java 11
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    # Try to find Java 11 via jenv or common locations
    if [ -d "$HOME/.jenv/versions/11.0.17" ]; then
        JAVACMD="$HOME/.jenv/versions/11.0.17/bin/java"
    elif [ -d "/Library/Java/JavaVirtualMachines/jdk-11.jdk/Contents/Home" ]; then
        JAVACMD="/Library/Java/JavaVirtualMachines/jdk-11.jdk/Contents/Home/bin/java"
    else
        JAVACMD="java"
    fi
fi

GRADLE_WRAPPER_JAR="$SCRIPT_DIR/gradle/wrapper-gradle8.5/gradle-wrapper.jar"
GRADLE_WRAPPER_PROPS="$SCRIPT_DIR/gradle/wrapper-gradle8.5/gradle-wrapper.properties"

exec "$JAVACMD" -classpath "$GRADLE_WRAPPER_JAR" \
    -Dorg.gradle.wrapper.properties="$GRADLE_WRAPPER_PROPS" \
    org.gradle.wrapper.GradleWrapperMain "$@"
